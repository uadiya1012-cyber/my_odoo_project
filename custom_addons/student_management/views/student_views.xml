<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.management</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first student
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_student_root" 
              name="Student Management" 
              sequence="10"/>
    
    <menuitem id="menu_student" 
              name="Students" 
              parent="menu_student_root" 
              action="action_student" 
              sequence="10"/>
              
    
    <record id="view_student_list" model="ir.ui.view">  
        <field name="name">student.management.list</field>  
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <list>  
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="enrollment_date"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.management.search</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Active" name="filter_active" domain="[('active','=',True)]"/>
                <filter string="Male" name="filter_male" domain="[('gender','=','male')]"/>
                <filter string="Female" name="filter_female" domain="[('gender','=','female')]"/>
                <filter string="Enrolled this year" name="filter_enrolled_year" domain="[('enrollment_date','&gt;=', (context_today()[:4] + '-01-01'))]"/>
                <group expand="false">
                    <field name="gender"/>
                    <field name="enrollment_date"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student.management.kanban</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_example">
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong t-esc="record.name.value"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div><span>Age:</span> <t t-esc="record.age.value or '-'"/></div>
                                <div><span>Gender:</span> <t t-esc="record.gender.value or '-'"/></div>
                                <div><span>Enrolled:</span> <t t-esc="record.enrollment_date.value or '-'"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Form View -->
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.management.form</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="enrollment_date"/>
                            <field name="email"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="message_ids" readonly="1"/>
                        </page>
                        <page string="Activities">
                            <field name="activity_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>