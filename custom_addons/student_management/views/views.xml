<odoo>
  <data noupdate="1">
    <!-- List view -->
    <record id="view_student_management_tree" model="ir.ui.view">
      <field name="name">student.management.tree</field>
      <field name="model">student.management</field>
      <field name="arch" type="xml">
        <tree string="Students">
          <field name="name"/>
          <field name="age"/>
          <field name="gender"/>
        </tree>
      </field>
    </record>

    <!-- Form view -->
    <record id="view_student_management_form" model="ir.ui.view">
      <field name="name">student.management.form</field>
      <field name="model">student.management</field>
      <field name="arch" type="xml">
        <form string="Student">
          <sheet>
            <group>
              <field name="name"/>
              <field name="age"/>
              <field name="gender"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Action -->
    <record id="action_student_management" model="ir.actions.act_window">
      <field name="name">Students</field>
      <field name="res_model">student.management</field>
      <field name="view_mode">tree,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Create your first student
        </p>
      </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_student_management_root" name="Students"/>
    <menuitem id="menu_student_management_list" name="Student List" parent="menu_student_management_root" action="action_student_management"/>
  </data>
</odoo>
